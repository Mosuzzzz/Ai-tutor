# --- Core ---
DATABASE_URL=sqlite:///./ai_tutor.db
JWT_SECRET_KEY=change-me-to-a-32+-byte-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Comma-separated browser origins allowed by CORS.
FRONTEND_URL=http://localhost:3000

# --- AI (optional; offline fallbacks used when empty) ---
GROQ_API_KEY=

# --- Google OAuth (consumer social login) ---
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be the callback below (origin must match where the
# backend is reachable by the browser):
#   <public-backend-origin>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional explicit callback URL; if empty it is derived from the request base URL.
GOOGLE_REDIRECT_URI=
# Where the browser is sent after sign-in completes (your app's origin).
OAUTH_SUCCESS_REDIRECT=http://localhost:3000
