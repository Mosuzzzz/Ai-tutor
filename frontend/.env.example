# Server-only FastAPI base URL for Next.js BFF route handlers.
# Do not prefix this with NEXT_PUBLIC because browser code must not call backend with tokens directly.
AI_TUTOR_BACKEND_URL=http://127.0.0.1:8000

# Trusted browser origins for BFF mutation routes that use Origin header CSRF protection.
AI_TUTOR_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
